{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.finance.manager",
  "productName": "Finance App",
  "version": "0.1.0",

  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },

  "app": {
    "windows": [
      {
        "title": "Finance App",
        "width": 1000,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true
  }
}
